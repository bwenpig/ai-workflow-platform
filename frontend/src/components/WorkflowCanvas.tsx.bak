import { useCallback, useState, useEffect, useRef } from 'react';
import {
  ReactFlow,
  Controls,
  Background,
  MiniMap,
  useNodesState,
  useEdgesState,
  addEdge,
  Connection,
  Edge,
  Node,
  NodeClickHandler,
  Handle,
  Position,
} from '@xyflow/react';
import '@xyflow/react/dist/style.css';
import ResultPreview from './ResultPreview';

// 简化的节点组件（只显示状态）
function SimpleNode({ data, id }: any) {
  return (
    <div style={{
      padding: '12px 20px',
      borderRadius: '8px',
      background: data.status === 'SUCCESS' ? '#d4edda' : 
                  data.status === 'FAILED' ? '#f8d7da' : 
                  data.status === 'RUNNING' ? '#fff3cd' : '#fff',
      border: `3px solid ${data.status === 'SUCCESS' ? '#28a745' : 
                          data.status === 'FAILED' ? '#dc3545' : 
                          data.status === 'RUNNING' ? '#ffc107' : '#dee2e6'}`,
      minWidth: '180px',
      boxShadow: '0 2px 8px rgba(0,0,0,0.15)',
    }}>
      <Handle type="target" position={Position.Top} />
      
      {/* 节点标题和状态 */}
      <div style={{ fontWeight: 'bold', fontSize: '16px', display: 'flex', alignItems: 'center', gap: '8px' }}>
        <span style={{ fontSize: '20px' }}>{data.icon}</span>
        <span>{data.label}</span>
        {data.status && (
          <span style={{
            fontSize: '16px',
            marginLeft: 'auto',
          }}>
            {data.status === 'SUCCESS' && '✅'}
            {data.status === 'FAILED' && '❌'}
            {data.status === 'RUNNING' && '⏳'}
          </span>
        )}
      </div>

      <Handle type="source" position={Position.Bottom} />
    </div>
  );
}

const nodeTypes = {
  simple: SimpleNode,
};

const initialNodes: Node[] = [
  {
    id: '1',
    type: 'simple',
    position: { x: 250, y: 50 },
    data: { label: '输入节点', icon: '📝' },
  },
  {
    id: '2',
    type: 'simple',
    position: { x: 250, y: 200 },
    data: { label: '可灵模型', icon: '🎨' },
  },
  {
    id: '3',
    type: 'simple',
    position: { x: 250, y: 350 },
    data: { label: '输出节点', icon: '📤' },
  },
];

const initialEdges: Edge[] = [
  { id: 'e1-2', source: '1', target: '2' },
  { id: 'e2-3', source: '2', target: '3' },
];

export default function WorkflowCanvas() {
  const [nodes, setNodes, onNodesChange] = useNodesState(initialNodes);
  const [edges, setEdges, onEdgesChange] = useEdgesState(initialEdges);
  
  const [selectedNode, setSelectedNode] = useState<Node | null>(null);
  const [showResultPreview, setShowResultPreview] = useState(false);
  const [isExecuting, setIsExecuting] = useState(false);
  const [executionResult, setExecutionResult] = useState<any>(null);
  const [currentWorkflowId, setCurrentWorkflowId] = useState<string | null>(null);
  const [executionId, setExecutionId] = useState<string | null>(null);
  const [nodeResults, setNodeResults] = useState<Record<string, any>>({});

  const pollIntervalRef = useRef<NodeJS.Timeout | null>(null);
  const pollCountRef = useRef(0);

  const onConnect = useCallback(
    (params: Connection) => setEdges((eds) => addEdge(params, eds)),
    [setEdges]
  );

  const addNode = (type: string, label: string) => {
    const newNode: Node = {
      id: `node-${Date.now()}`,
      type: 'simple',
      position: { x: Math.random() * 400 + 50, y: Math.random() * 400 + 50 },
      data: { label, icon: label.split(' ')[0] },
    };
    setNodes((nds) => [...nds, newNode]);
  };

  const onNodeClick: NodeClickHandler = useCallback((event, node) => {
    setSelectedNode(node);
  }, []);

  // 更新节点状态
  const updateNodeStatus = (nodeId: string, status: string, result?: any) => {
    setNodes((nds) =>
      nds.map((node) => {
        if (node.id === nodeId) {
          return {
            ...node,
            data: {
              ...node.data,
              status,
            },
          };
        }
        return node;
      })
    );
    
    // 同时更新外部结果面板
    if (result) {
      setNodeResults((prev) => ({
        ...prev,
        [nodeId]: { status, result, timestamp: new Date().toISOString() },
      }));
    }
  };

  // 轮询执行状态
  const pollExecutionStatus = async (execId: string) => {
    try {
      const response = await fetch(`http://localhost:8080/api/v1/executions/${execId}`);
      if (!response.ok) {
        return;
      }
      
      const status = await response.json();
      pollCountRef.current += 1;
      
      if (pollCountRef.current > 10) {
        if (pollIntervalRef.current) {
          clearInterval(pollIntervalRef.current);
          pollIntervalRef.current = null;
        }
        setIsExecuting(false);
        alert('执行超时，请重试');
        return;
      }
      
      if (status.nodeStates) {
        Object.entries(status.nodeStates).forEach(([nodeId, nodeState]: [string, any]) => {
          if (nodeState.status === 'SUCCESS') {
            updateNodeStatus(nodeId, 'SUCCESS', nodeState.result);
          } else if (nodeState.status === 'FAILED') {
            updateNodeStatus(nodeId, 'FAILED');
          } else if (nodeState.status === 'RUNNING') {
            updateNodeStatus(nodeId, 'RUNNING');
          }
        });
      }
      
      if (status.status === 'SUCCESS' || status.status === 'FAILED') {
        if (pollIntervalRef.current) {
          clearInterval(pollIntervalRef.current);
          pollIntervalRef.current = null;
        }
        
        setIsExecuting(false);
        
        const resultData = {
          executionId: execId,
          status: status.status,
          nodeStates: status.nodeStates,
        };
        
        setExecutionResult(resultData);
        setShowResultPreview(true);
      }
    } catch (error) {
      console.error('轮询失败:', error);
    }
  };

  const handleExecute = async () => {
    setIsExecuting(true);
    pollCountRef.current = 0;
    setNodeResults({});
    
    setNodes((nds) =>
      nds.map((node) => ({
        ...node,
        data: { ...node.data, status: undefined },
      }))
    );
    
    try {
      const workflowData = {
        name: '测试工作流',
        description: '从画布创建的工作流',
        nodes: nodes.map(node => ({
          nodeId: node.id,
          type: node.type?.toUpperCase() || 'DEFAULT',
          position: node.position,
          config: node.data.config || {},
          modelProvider: node.data.label?.includes('可灵') ? 'kling' : 
                        node.data.label?.includes('万相') ? 'wan' :
                        node.data.label?.includes('Seedance') ? 'seedance' :
                        node.data.label?.includes('NanoBanana') ? 'nanobanana' : undefined,
        })),
        edges: edges.map(edge => ({
          ...edge,
          dataType: 'text',
        })),
      };

      const saveResponse = await fetch('http://localhost:8080/api/v1/workflows', {
        method: 'POST',
        headers: {
          'Content-Type': 'application/json',
          'X-User-Id': 'ben-test',
        },
        body: JSON.stringify(workflowData),
      });

      const workflow = await saveResponse.json();
      setCurrentWorkflowId(workflow.id);

      const executeResponse = await fetch(`http://localhost:8080/api/v1/workflows/${workflow.id}/execute`, {
        method: 'POST',
        headers: {
          'Content-Type': 'application/json',
          'X-User-Id': 'ben-test',
        },
        body: JSON.stringify({}),
      });

      const executeResult = await executeResponse.json();
      setExecutionId(executeResult.executionId);

      pollIntervalRef.current = setInterval(() => {
        pollExecutionStatus(executeResult.executionId);
      }, 2000);

    } catch (error) {
      console.error('执行失败:', error);
      setIsExecuting(false);
      alert('执行失败：' + (error as Error).message);
    }
  };

  useEffect(() => {
    return () => {
      if (pollIntervalRef.current) {
        clearInterval(pollIntervalRef.current);
      }
    };
  }, []);

  // 配置变更处理
  const handleConfigChange = (key: string, value: any) => {
    if (!selectedNode) return;
    
    const newConfig = { ...selectedNode.data.config, [key]: value };
    setNodes((nds) =>
      nds.map((node) => {
        if (node.id === selectedNode.id) {
          return { ...node, data: { ...node.data, config: newConfig } };
        }
        return node;
      })
    );
    setSelectedNode({ ...selectedNode, data: { ...selectedNode.data, config: newConfig } });
  };

  return (
    <div style={{ width: '100vw', height: '100vh', display: 'flex' }}>
      {/* 左侧画布区域 */}
      <div style={{ flex: 1, position: 'relative' }}>
        {/* 顶部工具栏 */}
        <div style={{
          position: 'absolute',
          top: 10,
          left: 10,
          zIndex: 1000,
          background: 'white',
          padding: '10px',
          borderRadius: '8px',
          boxShadow: '0 2px 8px rgba(0,0,0,0.1)',
        }}>
          <h3 style={{ margin: '0 0 10px 0', fontSize: '14px' }}>节点工具箱</h3>
          <div style={{ display: 'flex', flexDirection: 'column', gap: '5px' }}>
            <button onClick={() => addNode('input', '📝 输入节点')}>📝 输入节点</button>
            <button onClick={() => addNode('model', '🎨 模型节点')}>🎨 模型节点</button>
            <button onClick={() => addNode('process', '⚙️ 处理节点')}>⚙️ 处理节点</button>
            <button onClick={() => addNode('output', '📤 输出节点')}>📤 输出节点</button>
          </div>
        </div>

        {/* 画布 */}
        <ReactFlow
          nodes={nodes}
          edges={edges}
          onNodesChange={onNodesChange}
          onEdgesChange={onEdgesChange}
          onConnect={onConnect}
          onNodeClick={onNodeClick}
          fitView
          nodeTypes={nodeTypes}
        >
          <Controls />
          <MiniMap 
            nodeStrokeColor={(n) => n.type === 'simple' ? '#0041d0' : '#1a192b'}
            nodeColor={(n) => {
              if (n.data?.status === 'SUCCESS') return '#d4edda';
              if (n.data?.status === 'FAILED') return '#f8d7da';
              if (n.data?.status === 'RUNNING') return '#fff3cd';
              return '#fff';
            }}
          />
          <Background variant="dots" gap={12} size={1} />
        </ReactFlow>
      </div>

      {/* 右侧信息面板 */}
      <div style={{
        width: '400px',
        background: '#f8f9fa',
        borderLeft: '1px solid #dee2e6',
        padding: '20px',
        overflowY: 'auto',
      }}>
        {/* 执行按钮 */}
        <div style={{ marginBottom: '20px' }}>
          <button
            onClick={handleExecute}
            disabled={isExecuting}
            style={{
              width: '100%',
              padding: '15px 20px',
              background: isExecuting ? '#ccc' : '#4CAF50',
              color: 'white',
              border: 'none',
              borderRadius: '8px',
              cursor: isExecuting ? 'not-allowed' : 'pointer',
              fontSize: '16px',
              fontWeight: 600,
              boxShadow: '0 2px 8px rgba(0,0,0,0.2)',
            }}
          >
            {isExecuting ? '⏳ 执行中...' : '▶️ 执行工作流'}
          </button>
        </div>

        {/* 选中节点的详细信息 */}
        {selectedNode ? (
          <>
            {/* 节点配置（直接编辑） */}
            <div style={{ marginBottom: '20px' }}>
              <h3 style={{ fontSize: '16px', fontWeight: 'bold', marginBottom: '10px', color: '#333' }}>
                ⚙️ {selectedNode.data.icon} {selectedNode.data.label} - 配置
              </h3>
              <div style={{ background: 'white', padding: '15px', borderRadius: '8px', border: '1px solid #dee2e6' }}>
                {/* 提示词输入框 */}
                <div style={{ marginBottom: '15px' }}>
                  <label style={{ display: 'block', fontWeight: 'bold', marginBottom: '5px', fontSize: '13px' }}>📝 提示词</label>
                  <textarea
                    value={selectedNode.data.config?.prompt || ''}
                    onChange={(e) => handleConfigChange('prompt', e.target.value)}
                    placeholder="输入提示词，例如：a beautiful cat running"
                    style={{ width: '100%', padding: '10px', border: '1px solid #ddd', borderRadius: '6px', fontSize: '13px', resize: 'vertical', minHeight: '80px', boxSizing: 'border-box' }}
                  />
                </div>

                {/* 时长输入框（仅模型节点显示） */}
                {(selectedNode.data.label?.includes('模型') || selectedNode.data.label?.includes('可灵')) && (
                  <>
                    <div style={{ marginBottom: '15px' }}>
                      <label style={{ display: 'block', fontWeight: 'bold', marginBottom: '5px', fontSize: '13px' }}>⏱️ 视频时长（秒）</label>
                      <input
                        type="number"
                        value={selectedNode.data.config?.duration || 5}
                        onChange={(e) => handleConfigChange('duration', parseInt(e.target.value) || 5)}
                        min="1"
                        max="30"
                        style={{ width: '100%', padding: '10px', border: '1px solid #ddd', borderRadius: '6px', fontSize: '13px', boxSizing: 'border-box' }}
                      />
                    </div>

                    <div style={{ marginBottom: '15px' }}>
                      <label style={{ display: 'block', fontWeight: 'bold', marginBottom: '5px', fontSize: '13px' }}>🎬 帧率（FPS）</label>
                      <select
                        value={selectedNode.data.config?.fps || 24}
                        onChange={(e) => handleConfigChange('fps', parseInt(e.target.value))}
                        style={{ width: '100%', padding: '10px', border: '1px solid #ddd', borderRadius: '6px', fontSize: '13px', boxSizing: 'border-box' }}
                      >
                        <option value="24">24 FPS（电影标准）</option>
                        <option value="30">30 FPS（电视标准）</option>
                        <option value="60">60 FPS（高帧率）</option>
                      </select>
                    </div>
                  </>
                )}

                {/* 尺寸选择（仅图片模型显示） */}
                {(selectedNode.data.label?.includes('万相') || selectedNode.data.label?.includes('NanoBanana')) && (
                  <div style={{ marginBottom: '15px' }}>
                    <label style={{ display: 'block', fontWeight: 'bold', marginBottom: '5px', fontSize: '13px' }}>🖼️ 图片尺寸</label>
                    <select
                      value={selectedNode.data.config?.size || '1024x1024'}
                      onChange={(e) => handleConfigChange('size', e.target.value)}
                      style={{ width: '100%', padding: '10px', border: '1px solid #ddd', borderRadius: '6px', fontSize: '13px', boxSizing: 'border-box' }}
                    >
                      <option value="512x512">512×512</option>
                      <option value="1024x1024">1024×1024（标准）</option>
                      <option value="1024x1536">1024×1536（竖版）</option>
                      <option value="1536x1024">1536×1024（横版）</option>
                    </select>
                  </div>
                )}

                {/* LLM 模型选择（仅 LLM 节点显示） */}
                {selectedNode.data.label?.includes('LLM') && (
                  <>
                    <div style={{ marginBottom: '15px' }}>
                      <label style={{ display: 'block', fontWeight: 'bold', marginBottom: '5px', fontSize: '13px' }}>🤖 模型选择</label>
                      <select
                        value={selectedNode.data.config?.model || 'qwen-plus'}
                        onChange={(e) => handleConfigChange('model', e.target.value)}
                        style={{ width: '100%', padding: '10px', border: '1px solid #ddd', borderRadius: '6px', fontSize: '13px', boxSizing: 'border-box' }}
                      >
                        <optgroup label="⭐ Qwen 系列（推荐）">
                          <option value="qwen-plus">Qwen-Plus（通义千问 Plus）</option>
                          <option value="qwen-max">Qwen-Max（通义千问 Max）</option>
                          <option value="qwen-turbo">Qwen-Turbo（通义千问 Turbo）</option>
                          <option value="qwen-long">Qwen-Long（长文本）</option>
                        </optgroup>
                        <optgroup label="🚀 MiniMax">
                          <option value="minimax-m2">MiniMax-M2</option>
                          <option value="minimax-m1">MiniMax-M1</option>
                        </optgroup>
                        <optgroup label="🌙 Kimi">
                          <option value="kimi-latest">Kimi（最新版）</option>
                          <option value="kimi-plus">Kimi Plus</option>
                        </optgroup>
                      </select>
                    </div>

                    <div style={{ marginBottom: '15px' }}>
                      <label style={{ display: 'block', fontWeight: 'bold', marginBottom: '5px', fontSize: '13px' }}>📋 系统提示词</label>
                      <textarea
                        value={selectedNode.data.config?.systemPrompt || '你是一个有用的 AI 助手'}
                        onChange={(e) => handleConfigChange('systemPrompt', e.target.value)}
                        placeholder="设置 AI 的角色和行为，例如：你是一个专业的编程助手"
                        style={{ width: '100%', padding: '10px', border: '1px solid #ddd', borderRadius: '6px', fontSize: '13px', resize: 'vertical', minHeight: '60px', boxSizing: 'border-box' }}
                      />
                    </div>

                    <div style={{ marginBottom: '15px' }}>
                      <label style={{ display: 'block', fontWeight: 'bold', marginBottom: '5px', fontSize: '13px' }}>🌡️ 温度（Temperature）</label>
                      <input
                        type="number"
                        value={selectedNode.data.config?.temperature || 0.7}
                        onChange={(e) => handleConfigChange('temperature', parseFloat(e.target.value) || 0.7)}
                        min="0"
                        max="2"
                        step="0.1"
                        style={{ width: '100%', padding: '10px', border: '1px solid #ddd', borderRadius: '6px', fontSize: '13px', boxSizing: 'border-box' }}
                      />
                      <div style={{ fontSize: '11px', color: '#999', marginTop: '4px' }}>
                        0 = 确定性，2 = 随机性，建议 0.5-1.0
                      </div>
                    </div>

                    <div style={{ marginBottom: '15px' }}>
                      <label style={{ display: 'block', fontWeight: 'bold', marginBottom: '5px', fontSize: '13px' }}>📏 最大 Tokens</label>
                      <input
                        type="number"
                        value={selectedNode.data.config?.maxTokens || 2048}
                        onChange={(e) => handleConfigChange('maxTokens', parseInt(e.target.value) || 2048)}
                        min="256"
                        max="32768"
                        step="256"
                        style={{ width: '100%', padding: '10px', border: '1px solid #ddd', borderRadius: '6px', fontSize: '13px', boxSizing: 'border-box' }}
                      />
                      <div style={{ fontSize: '11px', color: '#999', marginTop: '4px' }}>
                        控制输出长度，建议 1024-4096
                      </div>
                    </div>
                  </>
                )}

                {/* 保存提示 */}
                <div style={{ marginTop: '12px', padding: '10px', background: '#e7f3ff', color: '#0056b3', textAlign: 'center', borderRadius: '6px', fontSize: '12px' }}>
                  ✅ 配置已自动保存
                </div>
              </div>
            </div>

            {/* 节点执行结果 */}
            <div>
              <h3 style={{ fontSize: '16px', fontWeight: 'bold', marginBottom: '10px', color: '#333' }}>
                📤 {selectedNode.data.icon} {selectedNode.data.label} - 执行结果
              </h3>
              {nodeResults[selectedNode.id] ? (
                <div style={{
                  background: 'white',
                  padding: '15px',
                  borderRadius: '8px',
                  border: `2px solid ${nodeResults[selectedNode.id].status === 'SUCCESS' ? '#28a745' : 
                                      nodeResults[selectedNode.id].status === 'FAILED' ? '#dc3545' : 
                                      nodeResults[selectedNode.id].status === 'RUNNING' ? '#ffc107' : '#dee2e6'}`,
                }}>
                  <div style={{ fontWeight: 'bold', marginBottom: '12px', display: 'flex', alignItems: 'center', gap: '5px' }}>
                    <span>状态:</span>
                    <span style={{ marginLeft: 'auto', fontSize: '18px' }}>
                      {nodeResults[selectedNode.id].status === 'SUCCESS' && '✅ 成功'}
                      {nodeResults[selectedNode.id].status === 'FAILED' && '❌ 失败'}
                      {nodeResults[selectedNode.id].status === 'RUNNING' && '⏳ 执行中'}
                    </span>
                  </div>
                  
                  {nodeResults[selectedNode.id].result && (
                    <div style={{ marginTop: '12px' }}>
                      {nodeResults[selectedNode.id].result.type === 'video' && (
                        <div>
                          <div style={{ fontSize: '13px', color: '#666', marginBottom: '8px' }}>
                            🎬 视频 | {nodeResults[selectedNode.id].result.duration}秒 | {nodeResults[selectedNode.id].result.fps} FPS
                          </div>
                          {nodeResults[selectedNode.id].result.previewUrl && (
                            <img src={nodeResults[selectedNode.id].result.previewUrl} alt="预览" style={{ width: '100%', borderRadius: '4px', marginTop: '4px' }} />
                          )}
                          {nodeResults[selectedNode.id].result.url && (
                            <a href={nodeResults[selectedNode.id].result.url} target="_blank" rel="noopener noreferrer"
                              style={{ display: 'block', marginTop: '8px', padding: '10px', background: '#007bff', color: 'white', textAlign: 'center', borderRadius: '6px', textDecoration: 'none', fontSize: '13px' }}>
                              🔗 查看视频
                            </a>
                          )}
                        </div>
                      )}

                      {nodeResults[selectedNode.id].result.type === 'image' && (
                        <div>
                          <div style={{ fontSize: '13px', color: '#666', marginBottom: '8px' }}>
                            🖼️ 图片 | {nodeResults[selectedNode.id].result.width}×{nodeResults[selectedNode.id].result.height}
                          </div>
                          {nodeResults[selectedNode.id].result.url && (
                            <img src={nodeResults[selectedNode.id].result.url} alt="结果" style={{ width: '100%', borderRadius: '4px', marginTop: '4px' }} />
                          )}
                          {nodeResults[selectedNode.id].result.url && (
                            <a href={nodeResults[selectedNode.id].result.url} target="_blank" rel="noopener noreferrer"
                              style={{ display: 'block', marginTop: '8px', padding: '10px', background: '#007bff', color: 'white', textAlign: 'center', borderRadius: '6px', textDecoration: 'none', fontSize: '13px' }}>
                              🔗 查看大图
                            </a>
                          )}
                        </div>
                      )}
                    </div>
                  )}
                  
                  {nodeResults[selectedNode.id].timestamp && (
                    <div style={{ marginTop: '12px', paddingTop: '12px', borderTop: '1px solid #dee2e6', fontSize: '12px', color: '#999', textAlign: 'right' }}>
                      更新时间：{new Date(nodeResults[selectedNode.id].timestamp).toLocaleTimeString()}
                    </div>
                  )}
                </div>
              ) : (
                <div style={{ background: 'white', padding: '30px', borderRadius: '8px', border: '1px solid #dee2e6', textAlign: 'center', color: '#999', marginTop: '20px' }}>
                  <div style={{ fontSize: '24px', marginBottom: '8px' }}>⏳</div>
                  <div>暂无执行结果</div>
                  <div style={{ fontSize: '12px', marginTop: '4px' }}>点击上方按钮执行工作流</div>
                </div>
              )}
            </div>
          </>
        ) : (
          /* 未选中节点时的提示 */
          <div style={{ background: 'white', padding: '40px 20px', borderRadius: '8px', border: '1px solid #dee2e6', textAlign: 'center', color: '#999', marginTop: '20px' }}>
            <div style={{ fontSize: '48px', marginBottom: '16px' }}>👈</div>
            <div style={{ fontSize: '16px', fontWeight: 'bold', marginBottom: '8px' }}>点击左侧节点卡片</div>
            <div style={{ fontSize: '14px' }}>查看该节点的配置和执行结果</div>
          </div>
        )}
      </div>

      {/* 执行结果预览弹窗 */}
      {showResultPreview && executionResult && (
        <ResultPreview
          result={executionResult}
          onClose={() => {
            setShowResultPreview(false);
            setExecutionResult(null);
          }}
        />
      )}
    </div>
  );
}
